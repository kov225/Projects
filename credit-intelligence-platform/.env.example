# Environment variable template for Credit Intelligence Platform
# Copy this to .env and fill in your keys. Never commit .env to git.

# --- API Keys ---
FRED_API_KEY=b5a6c2d0b5601b9955d3c667212625e4
OPENAI_API_KEY=sk-your-openai-key-here
KAGGLE_USERNAME=koushikvennalakanti
KAGGLE_KEY=0c52df94ac8a09ce30046e4755469a91

# --- Explanation Backend: "openai" or "ollama" ---
EXPLANATION_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434

# --- A/B Testing ---
CHALLENGER_TRAFFIC_PCT=0.2

# --- Database ---
POSTGRES_USER=credit_app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=credit_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_SECONDS=3600

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=loan_applications
KAFKA_CONSUMER_GROUP=credit_scorer

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=credit_intelligence

# --- Model Config ---
CHAMPION_MODEL_NAME=credit_risk_champion
CHALLENGER_MODEL_NAME=credit_risk_challenger

# --- Drift Detection ---
PSI_THRESHOLD=0.2
KS_PVALUE_THRESHOLD=0.05
AUC_DROP_THRESHOLD=0.03
DRIFT_WINDOW_SIZE=1000
HOLDOUT_SIZE=500

# --- Retraining ---
RETRAIN_CHECK_INTERVAL_HOURS=6
MIN_AUC_IMPROVEMENT=0.005
