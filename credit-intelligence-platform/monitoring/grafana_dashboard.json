{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Credit Intelligence Platform - real-time monitoring dashboard",
  "editable": true,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Requests per Minute",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(credit_scorer_requests_total[1m])) * 60",
          "legendFormat": "req/min"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 500 }] } } }
    },
    {
      "type": "stat",
      "title": "p99 Latency (ms)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(credit_scorer_request_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p99 latency"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 120 }] } } }
    },
    {
      "type": "stat",
      "title": "p95 Latency (ms)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(credit_scorer_request_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95 latency"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(credit_scorer_errors_total[5m]))",
          "legendFormat": "errors/sec"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.1 }] } } }
    },
    {
      "type": "timeseries",
      "title": "Request Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(credit_scorer_request_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(credit_scorer_request_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(credit_scorer_request_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Champion vs Challenger Decision Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "sum(rate(credit_scorer_requests_total{decision='deny'}[5m])) by (model_role) / sum(rate(credit_scorer_requests_total[5m])) by (model_role)", "legendFormat": "deny rate - {{model_role}}" },
        { "expr": "sum(rate(credit_scorer_requests_total{decision='approve'}[5m])) by (model_role) / sum(rate(credit_scorer_requests_total[5m])) by (model_role)", "legendFormat": "approve rate - {{model_role}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "timeseries",
      "title": "Drift PSI Scores - Top Features",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "credit_scorer_drift_psi", "legendFormat": "{{feature}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.2 }] },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Rolling AUC by Model Version",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "credit_scorer_rolling_auc", "legendFormat": "{{model_version}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0.5,
          "max": 1.0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.72 }, { "color": "green", "value": 0.78 }] }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Risk Score Distribution",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        { "expr": "histogram_quantile(0.25, sum(rate(credit_scorer_risk_score_bucket[10m])) by (le, model_role))", "legendFormat": "p25 - {{model_role}}" },
        { "expr": "histogram_quantile(0.50, sum(rate(credit_scorer_risk_score_bucket[10m])) by (le, model_role))", "legendFormat": "p50 - {{model_role}}" },
        { "expr": "histogram_quantile(0.75, sum(rate(credit_scorer_risk_score_bucket[10m])) by (le, model_role))", "legendFormat": "p75 - {{model_role}}" }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 1 } }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["credit", "ml", "monitoring"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "Credit Intelligence Platform",
  "uid": "credit-intelligence-v1",
  "version": 1
}
